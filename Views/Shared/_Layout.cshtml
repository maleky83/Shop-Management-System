<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"]</title>
	@* <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" /> *@
	<link href="~/css/bootstrap-rtl.css" rel="stylesheet" />
	@* <link rel="stylesheet" href="~/css/site.css" /> *@
</head>
<body class="rtl" style="font-family:Sahel,sans-serif;">
	<header>
		<nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
			<div class="container">
				<a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">فروشگاه</a>
				<button class="navbar-toggler" type="button" data-toggle="collapse" data-target=".navbar-collapse" aria-controls="navbarSupportedContent"
						aria-expanded="false" aria-label="Toggle navigation">
					<span class="navbar-toggler-icon"></span>
				</button>
				<div class="navbar-collapse collapse d-sm-inline-flex flex-sm-row-reverse">
					<ul class="navbar-nav flex-grow-1">
						<li class="nav-item">
							<a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">خانه</a>
						</li>
						<li class="nav-item">
							<a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="ContactUs">تماس با ما</a>
						</li>
						<partial name="_Groups" />
						@if (User.Identity.IsAuthenticated)
						{
							<li class="nav-item">
								<a class="nav-link text-dark"
								   asp-controller="home"
								   asp-action="showCart">
									سبد خرید
								</a>
							</li>
							<li class="nav-item">
								<h5 class="text-dark">@User.Identity.Name</h5>
							</li>
							<li class="nav-item">
								<a asp-controller="Account"
								   asp-action="Logout">
									خروج
								</a>
							</li>
						}
						else
						{
							<li class="nav-item">
								<a class="btn btn-outline-primary"
								   asp-controller="Account"
								   asp-action="Register">
									ثبت نام
								</a>
							</li>
							<li class="nav-item">
								<a class="btn btn-outline-primary"
								   asp-controller="Account"
								   asp-action="Login">
									ورود
								</a>
							</li>
						}
						<li class="nav-item">
							<a asp-controller="Admin"
							   asp-action="Index">
								پنل ادمین
							</a>
						</li>
					</ul>
				</div>
			</div>
		</nav>
	</header>
	<div class="container">
		<div class="row">
			<div class="col-md-3">
				@await Component.InvokeAsync("ProductGroupsComponent")
			</div>
			<div class="col-md-9">
				@RenderBody()
			</div>
		</div>
	</div>

	<footer class="border-top footer text-muted">
		<div class="container">
			&copy; 2026 - program - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
		</div>
	</footer>
	<script src="~/lib/jquery/dist/jquery.min.js"></script>
	<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
	<script src="~/js/site.js" asp-append-version="true"></script>
	@RenderSection("Scripts", required: false)
</body>
</html>
